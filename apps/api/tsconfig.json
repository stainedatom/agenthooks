{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "target": "es2021",
    "moduleResolution": "nodenext",
    "sourceMap": false,
    "outDir": "./build",
    "rootDir": "./src",
    "types": ["./src/types/express.d.ts"],
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
